# ============================================================
# Luxora Theme — Deployment Configuration
# ============================================================
# COPY this file to .env and fill in your real credentials.
# .env is listed in .gitignore and will NEVER be committed.
# ============================================================

# --- Tìm ở đâu? ---
# hPanel → Hosting → Manage → SSH Access
# hoặc hPanel → Advanced → SSH

# Hostname của server (vd: srv1234.hstgr.io)
DEPLOY_HOST=srv1234.hstgr.io

# Port SSH của Hostinger (mặc định 65002, KHÔNG phải 22)
DEPLOY_PORT=65002

# Username SSH (vd: u123456789)
DEPLOY_USER=u123456789

# Password SSH
DEPLOY_PASS=your_ssh_password_here

# Đường dẫn đầy đủ tới thư mục theme trên server
# Thường là: /home/[username]/public_html/wp-content/themes/luxora-theme
# Nếu WordPress cài trong subfolder vd /blog: /home/[username]/public_html/blog/wp-content/themes/luxora-theme
DEPLOY_REMOTE_PATH=/home/u123456789/public_html/wp-content/themes/luxora-theme
